# Goldfish backend — vereiste environment variables.
# Kopieer naar src/.env (of .env in de projectroot) en vul in.
# Commit nooit een echt .env-bestand.

# PostgreSQL-connectiestring van de app-gebruiker
DATABASE_URL=postgresql://goldfish:CHANGE_ME@localhost:5432/goldfish

# Secret voor het ondertekenen van JWT's. Genereer met:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME

# Poort waarop de Node-app luistert (de reverse proxy stuurt hierheen door)
PORT=3000

# Bind-adres. In productie (achter Caddy/nginx op dezelfde machine) op
# 127.0.0.1 zetten zodat de app niet rechtstreeks vanaf het netwerk
# bereikbaar is. Weglaten/0.0.0.0 = bereikbaar op alle interfaces (alleen
# voor lokale ontwikkeling).
HOST=127.0.0.1

# Resend (transactionele e-mail voor accountverificatie)
RESEND_API_KEY=CHANGE_ME
FROM_EMAIL=Goldfish <noreply@example.com>

# Publieke basis-URL van de API; wordt gebruikt in verificatielinks in e-mails.
# Achter de proxy is dit dus https://<jouw-domein>.
APP_URL=https://api.goldfish.example

# Optioneel — interval van de server-side WebSocket-heartbeat in ms
# (standaard 30000; verbindingen zonder pong worden na ~2 intervallen gesloten)
# WS_HEARTBEAT_INTERVAL_MS=30000

# Optioneel — zet op 1 voor debug-logging van genegeerde/foute WS-berichten
# WS_DEBUG=1

# Optioneel — laagste API-versie die de server nog accepteert (standaard 1).
# Op 2 zetten om v1 en de ongeprefixte legacy-paden af te sluiten: oude
# clients krijgen dan op elke call een 410 api_version_unsupported.
# MIN_API_VERSION=1

# Optioneel — extra toegestane CORS-origins voor de browser (Flutter web),
# komma-gescheiden. Elke localhost/127.0.0.1-origin is altijd toegestaan
# (dev-server kiest een willekeurige poort); zet hier de PRODUCTIE-origin(s)
# van de webapp bij, bijv. https://app.goldfish.example. Native apps doen
# geen CORS en worden niet geraakt.
# CORS_ORIGINS=https://app.goldfish.example
